<!-- Email capture component — Swiss flat box -->
<section class="section" id="newsletter">
  <div class="container">
    <div class="email-capture">
      <h3>Get the template pack</h3>
      <p>Every dispute letter, bureau response script, and playbook on this site — downloadable as a single pack. One email, no spam.</p>
      <form action="https://buttondown.com/api/emails/embed-subscribe/creditcookbook" method="post" target="popupwindow" onsubmit="window.open('https://buttondown.com/creditcookbook', 'popupwindow'); return true;">
        <input type="email" name="email" placeholder="you@email.com" required />
        <input type="hidden" name="embed" value="1" />
        <button type="submit">Subscribe</button>
      </form>
      <p class="fine">biweekly newsletter · unsubscribe anytime · no credit-repair upsells</p>
    </div>
  </div>
</section>
