---
import '../styles/global.css';
import '../styles/tokens.css';

interface Props {
  title: string;
  description: string;
  posterTitle?: string;
  posterLabel?: string;
}

const { title, description, posterTitle, posterLabel } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

  <!-- Schema.org Organization (sitewide) -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Caleb Pierre Ventures LLC",
    "alternateName": "CreditCookbook",
    "url": "https://creditcookbook.com",
    "logo": "https://creditcookbook.com/favicon.svg",
    "sameAs": [
      "https://github.com/ghettoeinstein/creditcookbook.com",
      "https://linkedin.com/in/calebpierre",
      "https://instagram.com/emperorpierre"
    ]
  })} />
</head>
<body>

  <!-- Nav — inline, not floating -->
  <nav class="nav">
    <div class="container">
      <a href="/" class="logo">
        <span class="logo-mark"></span>
        <span data-en="creditcookbook" data-es="creditcookbook">creditcookbook</span>
      </a>
      <div class="links">
        <a href="/" data-en="Home" data-es="Inicio">Home</a>
        <a href="/personal-credit" data-en="Personal Credit" data-es="Crédito Personal">Personal Credit</a>
        <a href="/business-credit" data-en="Business Credit" data-es="Crédito Comercial">Business Credit</a>
        <a href="/recipes" data-en="Recipes" data-es="Recetas">Recipes</a>
        <a href="/tools" data-en="Tools" data-es="Herramientas">Tools</a>
        <a href="/resources" data-en="Resources" data-es="Recursos">Resources</a>
        <a href="/about" data-en="About" data-es="Acerca de">About</a>
        <!-- Language toggle -->
        <button id="lang-toggle" class="lang-toggle" aria-label="Toggle language">
          <span class="lang-en lang-active">EN</span>
          <span class="lang-sep">|</span>
          <span class="lang-es">ES</span>
        </button>
      </div>
    </div>
  </nav>

  <!-- Poster block (only if provided) -->
  {posterTitle && (
    <section class="poster-block">
      <div class="container">
        {posterLabel && <span class="label">{posterLabel}</span>}
        <h1>{posterTitle}</h1>
      </div>
    </section>
  )}

  <!-- Page content -->
  <slot />

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="footer-left">
        <span>© 2026 CreditCookbook · <span data-en="open-source credit education" data-es="educación crediticia de código abierto">open-source credit education</span> · <a href="https://github.com/ghettoeinstein/creditcookbook.com">GitHub</a></span>
      </div>
      <div class="footer-legal">
        <a href="/personal-credit" data-en="Personal Credit" data-es="Crédito Personal">Personal Credit</a>
        <a href="/business-credit" data-en="Business Credit" data-es="Crédito Comercial">Business Credit</a>
        <a href="/tools" data-en="Tools" data-es="Herramientas">Tools</a>
        <a href="/resources" data-en="Resources" data-es="Recursos">Resources</a>
        <a href="/about" data-en="About" data-es="Acerca de">About</a>
        <a href="/contact" data-en="Contact" data-es="Contacto">Contact</a>
        <a href="/privacy" data-en="Privacy" data-es="Privacidad">Privacy</a>
        <a href="/terms" data-en="Terms" data-es="Términos">Terms</a>
      </div>
      <div class="footer-social">
        <a href="https://linkedin.com/in/calebpierre" target="_blank" rel="noopener">LinkedIn</a>
        <a href="https://instagram.com/emperorpierre" target="_blank" rel="noopener">Instagram</a>
      </div>
    </div>
  </footer>

  <!-- GSAP + ScrollTrigger via CDN -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" defer></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" defer></script>

  <!-- Language toggle — vanilla JS, reads/saves to localStorage -->
  <script is:inline>
    (function() {
      var lang = localStorage.getItem('cc-lang') || 'en';
      
      function applyLang(l) {
        document.documentElement.lang = l;
        document.querySelectorAll('[data-en]').forEach(function(el) {
          var text = el.getAttribute('data-' + l);
          if (text) el.textContent = text;
        });
        // Update toggle button
        var enBtn = document.querySelector('.lang-en');
        var esBtn = document.querySelector('.lang-es');
        if (enBtn && esBtn) {
          if (l === 'en') {
            enBtn.classList.add('lang-active');
            esBtn.classList.remove('lang-active');
          } else {
            esBtn.classList.add('lang-active');
            enBtn.classList.remove('lang-active');
          }
        }
      }
      
      // Apply on load
      applyLang(lang);
      
      // Toggle on click
      document.addEventListener('DOMContentLoaded', function() {
        var toggle = document.getElementById('lang-toggle');
        if (toggle) {
          toggle.addEventListener('click', function() {
            var current = localStorage.getItem('cc-lang') || 'en';
            var next = current === 'en' ? 'es' : 'en';
            localStorage.setItem('cc-lang', next);
            applyLang(next);
          });
        }
      });
    })();
  </script>

  <!-- Motion controller: reduced-motion guard + universal reveal system -->
  <script is:inline>
    (function () {
      function initMotion() {
        var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        var isTouch = window.matchMedia('(pointer: coarse)').matches;

        if (typeof gsap === 'undefined') {
          return setTimeout(initMotion, 50);
        }
        if (typeof ScrollTrigger !== 'undefined') {
          gsap.registerPlugin(ScrollTrigger);
        }

        if (reduceMotion) {
          document.querySelectorAll('[data-animate]').forEach(function (el) {
            el.style.opacity = '1';
            el.style.transform = 'none';
          });
          return;
        }

        var revealEls = document.querySelectorAll('[data-animate]');
        revealEls.forEach(function (el) {
          var y = el.getAttribute('data-animate-y') || '24';
          var delay = el.getAttribute('data-animate-delay') || '0';
          var duration = el.getAttribute('data-animate-duration') || '0.8';
          var stagger = el.getAttribute('data-animate-stagger');

          if (stagger && el.children.length > 1) {
            gsap.set(el.children, { opacity: 0, y: y });
            ScrollTrigger.create({
              trigger: el,
              start: 'top 85%',
              once: true,
              onEnter: function () {
                gsap.to(el.children, {
                  opacity: 1,
                  y: 0,
                  duration: parseFloat(duration),
                  ease: 'power3.out',
                  stagger: parseFloat(stagger)
                });
              }
            });
          } else {
            gsap.set(el, { opacity: 0, y: y });
            ScrollTrigger.create({
              trigger: el,
              start: 'top 85%',
              once: true,
              onEnter: function () {
                gsap.to(el, {
                  opacity: 1,
                  y: 0,
                  duration: parseFloat(duration),
                  ease: 'power3.out',
                  delay: parseFloat(delay)
                });
              }
            });
          }
        });

        if (!isTouch) {
          document.querySelectorAll('[data-parallax]').forEach(function (el) {
            var speed = parseFloat(el.getAttribute('data-parallax')) || 0.3;
            gsap.to(el, {
              y: function () { return (1 - speed) * 100; },
              ease: 'none',
              scrollTrigger: { trigger: el, start: 'top top', end: 'bottom top', scrub: speed }
            });
          });

          document.querySelectorAll('[data-tilt]').forEach(function (card) {
            var maxRotate = parseFloat(card.getAttribute('data-tilt')) || 4;
            card.style.transformStyle = 'preserve-3d';
            card.style.perspective = '800px';

            card.addEventListener('mousemove', function (e) {
              var rect = card.getBoundingClientRect();
              var x = e.clientX - rect.left;
              var y = e.clientY - rect.top;
              var centerX = rect.width / 2;
              var centerY = rect.height / 2;
              var rotateX = ((y - centerY) / centerY) * -maxRotate;
              var rotateY = ((x - centerX) / centerX) * maxRotate;

              gsap.to(card, {
                rotateX: rotateX, rotateY: rotateY,
                duration: 0.3, ease: 'power2.out', transformPerspective: 800
              });
            });

            card.addEventListener('mouseleave', function () {
              gsap.to(card, {
                rotateX: 0, rotateY: 0,
                duration: 0.6, ease: 'power3.out'
              });
            });
          });
        }
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initMotion);
      } else {
        initMotion();
      }
    })();
  </script>

</body>
</html>
