---
import Base from '../layouts/Base.astro';
import EmailCapture from '../components/EmailCapture.astro';

const description = 'Open-source credit education. Dispute letters, bureau response scripts, and credit-building playbooks — free, inspectable, community-verifiable. Remedy, not repair.';
---

<Base title="CreditCookbook — Open-Source Credit Education" description={description}>
  <!-- Hero -->
  <section class="poster-block">
    <div class="container">
      <span class="label">// open-source credit education</span>
      <h1>Remedy,<br />not repair.</h1>
    </div>
  </section>

  <section class="section" style="padding-top: 64px; padding-bottom: 64px;">
    <div class="container">
      <div class="grid" style="grid-template-columns: 1fr 1fr; gap: 48px; align-items: start;">
        <div>
          <p style="font-size: 19px; max-width: 52ch; color: var(--ink); opacity: 0.8;">
            Every dispute letter, bureau response script, and credit-building playbook — free, versioned, and inspectable on GitHub. No paid service. No upsell. Just the templates.
          </p>
        </div>
        <div>
          <p style="font-size: 15px; max-width: 48ch; color: var(--ink); opacity: 0.6;">
            CreditCookbook is an open, inspectable, community-verifiable source of credit dispute knowledge — hosted on GitHub, generated as a static site, and monetized through affiliate partnerships and a newsletter instead of selling services.
          </p>
        </div>
      </div>
      <div style="display: flex; gap: 16px; flex-wrap: wrap; margin-top: 40px;">
        <a href="/personal-credit" class="btn btn-primary">Start with Personal Credit</a>
        <a href="/recipes" class="btn btn-ghost">Browse Recipes</a>
        <a href="https://github.com/ghettoeinstein/creditcookbook.com" class="btn btn-ghost" target="_blank" rel="noopener">View on GitHub</a>
      </div>
    </div>
  </section>

  <hr class="rule" />

  <!-- How it works: 3 steps -->
  <section class="section" id="how-it-works">
    <div class="container">
      <span class="section-label">// how it works</span>
      <h2 style="margin-bottom: 48px;">Three steps. No middleman.</h2>

      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; border: 1px solid var(--line);">
        <!-- Step 1 -->
        <div style="padding: 40px; border-right: 1px solid var(--line);">
          <span class="mono" style="font-size: 12px; color: var(--blue); letter-spacing: 0.1em; text-transform: uppercase;">// step 01</span>
          <h3 style="margin-top: 16px; margin-bottom: 12px; font-size: 1.5rem;">Know Your Rights</h3>
          <p style="font-size: 14px; opacity: 0.7; line-height: 1.75;">The FCRA, FDCPA, and HIPAA give you tools most people pay $1,200/year to access. Read the statutes, understand what bureaus can and cannot report, and learn what makes a dispute legally valid.</p>
          <a href="/resources" class="mono" style="display: inline-block; margin-top: 20px; font-size: 12px; color: var(--blue);">→ Explore resources</a>
        </div>

        <!-- Step 2 -->
        <div style="padding: 40px; border-right: 1px solid var(--line);">
          <span class="mono" style="font-size: 12px; color: var(--blue); letter-spacing: 0.1em; text-transform: uppercase;">// step 02</span>
          <h3 style="margin-top: 16px; margin-bottom: 12px; font-size: 1.5rem;">Enforce</h3>
          <p style="font-size: 14px; opacity: 0.7; line-height: 1.75;">Send the right letter to the right party. Every template here is fill-in-the-blank, cites the statute, and has been stress-tested against real bureau responses. Track your disputes and follow up.</p>
          <a href="/recipes" class="mono" style="display: inline-block; margin-top: 20px; font-size: 12px; color: var(--blue);">→ Browse recipes</a>
        </div>

        <!-- Step 3 -->
        <div style="padding: 40px;">
          <span class="mono" style="font-size: 12px; color: var(--blue); letter-spacing: 0.1em; text-transform: uppercase;">// step 03</span>
          <h3 style="margin-top: 16px; margin-bottom: 12px; font-size: 1.5rem;">Build</h3>
          <p style="font-size: 14px; opacity: 0.7; line-height: 1.75;">Removing negatives is half the job. Building positive history is the other half. Secured cards, credit-builder loans, authorized user strategies — the playbooks that actually move your score.</p>
          <a href="/tools" class="mono" style="display: inline-block; margin-top: 20px; font-size: 12px; color: var(--blue);">→ See tools</a>
        </div>
      </div>
    </div>
  </section>

  <hr class="rule" />

  <!-- Featured Recipes -->
  <section class="section" id="featured-recipes">
    <div class="container">
      <span class="section-label">// featured recipes</span>
      <h2 style="margin-bottom: 12px;">Start with a recipe.</h2>
      <p style="max-width: 50ch; opacity: 0.7; margin-bottom: 48px;">Each recipe is a complete playbook — dispute letters, bureau scripts, step-by-step instructions, and FAQ with schema.org markup.</p>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 0; border: 1px solid var(--line);">
        <!-- Medical Debt (live) -->
        <a href="/medical-debt" style="display: block; padding: 32px; border-right: 1px solid var(--line); border-bottom: 1px solid var(--line); text-decoration: none; color: var(--ink); transition: background 0.15s;">
          <span class="section-label" style="margin-bottom: 8px;">// recipe 01</span>
          <h3 style="margin-bottom: 8px;">Medical Debt Removal</h3>
          <p style="font-size: 14px; opacity: 0.7;">Dispute medical collections, negotiate hospital bills, remove paid medical debt from your report.</p>
          <p class="mono" style="margin-top: 16px; color: var(--blue); font-size: 12px;">12 pages →</p>
        </a>

        <!-- Coming soon: Collections -->
        <div style="padding: 32px; border-right: 1px solid var(--line); border-bottom: 1px solid var(--line); opacity: 0.4;">
          <span class="section-label" style="margin-bottom: 8px;">// recipe 02</span>
          <h3 style="margin-bottom: 8px;">Collections Dispute</h3>
          <p style="font-size: 14px;">Validate, dispute, and negotiate collection accounts.</p>
          <p class="mono" style="margin-top: 16px; font-size: 12px;">coming soon</p>
        </div>

        <!-- Coming soon: Late Payments -->
        <div style="padding: 32px; border-right: 1px solid var(--line); border-bottom: 1px solid var(--line); opacity: 0.4;">
          <span class="section-label" style="margin-bottom: 8px;">// recipe 03</span>
          <h3 style="margin-bottom: 8px;">Late Payments</h3>
          <p style="font-size: 14px;">Goodwill letters, pay-for-delete, and dispute strategies.</p>
          <p class="mono" style="margin-top: 16px; font-size: 12px;">coming soon</p>
        </div>

        <!-- Coming soon: Hard Inquiries -->
        <div style="padding: 32px; border-bottom: 1px solid var(--line); opacity: 0.4;">
          <span class="section-label" style="margin-bottom: 8px;">// recipe 04</span>
          <h3 style="margin-bottom: 8px;">Hard Inquiries</h3>
          <p style="font-size: 14px;">Remove unauthorized inquiries and protect your score.</p>
          <p class="mono" style="margin-top: 16px; font-size: 12px;">coming soon</p>
        </div>
      </div>

      <div style="margin-top: 32px;">
        <a href="/recipes" class="mono" style="font-size: 13px; color: var(--blue);">→ See all recipes</a>
      </div>
    </div>
  </section>

  <hr class="rule" />

  <!-- Trust bar -->
  <section class="section" style="padding: 48px 0;">
    <div class="container">
      <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; border: 1px solid var(--line);">
        <div style="padding: 28px; border-right: 1px solid var(--line);">
          <span class="mono" style="font-size: 28px; font-weight: 600; color: var(--blue); display: block;">100%</span>
          <span class="mono" style="font-size: 11px; letter-spacing: 0.05em; opacity: 0.6;">OPEN SOURCE — MIT LICENSE</span>
        </div>
        <div style="padding: 28px; border-right: 1px solid var(--line);">
          <span class="mono" style="font-size: 28px; font-weight: 600; color: var(--blue); display: block;">$0</span>
          <span class="mono" style="font-size: 11px; letter-spacing: 0.05em; opacity: 0.6;">NO PAYWALL — NO UPSELL</span>
        </div>
        <div style="padding: 28px; border-right: 1px solid var(--line);">
          <span class="mono" style="font-size: 28px; font-weight: 600; color: var(--blue); display: block;">12</span>
          <span class="mono" style="font-size: 11px; letter-spacing: 0.05em; opacity: 0.6;">LIVE RECIPES & TEMPLATES</span>
        </div>
        <div style="padding: 28px;">
          <span class="mono" style="font-size: 28px; font-weight: 600; color: var(--blue); display: block;">∞</span>
          <span class="mono" style="font-size: 11px; letter-spacing: 0.05em; opacity: 0.6;">INSPECTABLE ON GITHUB</span>
        </div>
      </div>
    </div>
  </section>

  <hr class="rule" />

  <!-- Newsletter -->
  <EmailCapture />

</Base>
