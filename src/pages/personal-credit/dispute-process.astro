---
import Base from '../../layouts/Base.astro';

const description = 'How credit reporting works, step-by-step dispute walkthrough, letter templates by scenario, MOV requests, and legal timelines. The complete FCRA dispute process guide — free and open-source.';

// HowTo schema for structured data
const howtoSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to Dispute an Error on Your Credit Report",
  "description": "A step-by-step guide to disputing inaccurate, incomplete, or unverifiable items on your credit report under the Fair Credit Reporting Act (FCRA).",
  "totalTime": "PT45D",
  "estimatedCost": { "@type": "MonetaryAmount", "currency": "USD", "value": "7" },
  "supply": [
    { "@type": "HowToSupply", "name": "Copy of your credit report" },
    { "@type": "HowToSupply", "name": "USPS Certified Mail with Return Receipt" }
  ],
  "step": [
    { "@type": "HowToStep", "position": 1, "name": "Get your credit report", "text": "Download free reports from annualcreditreport.com or dispute directly on each bureau's website." },
    { "@type": "HowToStep", "position": 2, "name": "Identify errors", "text": "Review for inaccurate account details, wrong balances, duplicate entries, accounts that aren't yours, or obsolete items older than 7 years." },
    { "@type": "HowToStep", "position": 3, "name": "Write your dispute letter", "text": "Use the appropriate template for your scenario: inaccurate, unverifiable, identity theft, obsolete, or mixed file. Fill in all bracketed fields." },
    { "@type": "HowToStep", "position": 4, "name": "Send to all three bureaus", "text": "Mail separate letters to Experian, Equifax, and TransUnion via USPS Certified Mail with Return Receipt. Keep tracking numbers." },
    { "@type": "HowToStep", "position": 5, "name": "Wait for investigation", "text": "Bureaus have 30 days to investigate (45 if you send additional info during the dispute window). They must forward your dispute to the furnisher." },
    { "@type": "HowToStep", "position": 6, "name": "Review results", "text": "Bureaus must send written results within 5 days of completing the investigation. If unverifiable, the item must be deleted." },
    { "@type": "HowToStep", "position": 7, "name": "Send MOV request if verified", "text": "If the bureau verifies but doesn't remove, request the Method of Verification under FCRA §611(a)(7) within 15 days." }
  ]
};

const bureauAddresses = [
  { name: 'Experian', address: 'P.O. Box 9701, Allen, TX 75013', phone: '1-888-397-3742', online: 'experian.com/dispute' },
  { name: 'Equifax', address: 'P.O. Box 105069, Atlanta, GA 30348', phone: '1-800-685-1111', online: 'equifax.com/dispute' },
  { name: 'TransUnion', address: 'P.O. Box 2000, Chester, PA 19016', phone: '1-800-916-8800', online: 'transunion.com/dispute' },
];

const reportingSteps = [
  { step: '1', actor: 'Creditor / Furnisher', action: 'Lender, creditor, or collection agency reports account data to bureaus', fcra: 'FCRA §623' },
  { step: '2', actor: 'Credit Bureau', action: 'Experian, Equifax, or TransUnion stores the data in your credit file', fcra: 'FCRA §609' },
  { step: '3', actor: 'Furnisher (again)', action: 'Furnisher must provide accurate and complete information, correct errors', fcra: 'FCRA §623(a)(2)' },
  { step: '4', actor: 'Consumer (You)', action: 'You review your report and dispute any inaccuracies', fcra: 'FCRA §611' },
  { step: '5', actor: 'Bureau + Furnisher', action: 'Bureau investigates within 30 days; furnisher reviews and confirms/corrects', fcra: 'FCRA §611(a)' },
  { step: '6', actor: 'Bureau', action: 'Bureau sends results, updates file, and provides updated report if requested', fcra: 'FCRA §611(a)(6)' },
];

const disputeSteps = [
  { num: '01', title: 'Get your credit report', desc: 'Download free reports from annualcreditreport.com. You are entitled to one free report per bureau per year, plus additional free reports under FCRA §612 if denied credit, unemployed, on public assistance, or a victim of fraud.' },
  { num: '02', title: 'Identify errors', desc: 'Review every account for accuracy: account names, balances, payment history, dates opened/closed, account status, and whether each account is actually yours. Look for duplicates, mixed files, and items older than 7 years (10 for bankruptcy).' },
  { num: '03', title: 'Write your dispute letter', desc: 'Choose the template that matches your scenario below. Fill in all bracketed fields. Be specific about what is inaccurate and why. Cite FCRA §611 when asserting your right to dispute.' },
  { num: '04', title: 'Send to all three bureaus', desc: 'Mail separate letters to Experian, Equifax, and TransUnion. Send via USPS Certified Mail with Return Receipt — this creates a legal paper trail. Keep the tracking number and receipt. Online disputes are faster but may waive some rights.' },
  { num: '05', title: 'Wait for investigation', desc: 'Bureaus have 30 days to investigate from receipt of your dispute (45 days if you submit additional information during the 30-day window). The bureau must forward your dispute to the furnisher within 5 business days.' },
  { num: '06', title: 'Review results', desc: 'The bureau must send you written results within 5 business days of completing the investigation. If the item is unverifiable, it must be deleted. If corrected, you get a free updated report. If the furnisher confirms, the item stays.' },
  { num: '07', title: 'Send MOV request if verified', desc: 'If the bureau verifies the item but does not remove it, request the Method of Verification under FCRA §611(a)(7) within 15 days of receiving results. The bureau must describe how it verified the item within 15 days of your MOV request.' },
];
---

<Base title="The Dispute Process — Personal Credit — CreditCookbook" description={description} posterTitle="THE DISPUTE PROCESS" posterLabel="// 02 — how to dispute anything on your credit report">
  <script type="application/ld+json" is:inline set:html={JSON.stringify(howtoSchema)} />

  <!-- How credit reporting works -->
  <section class="section">
    <div class="container">
      <span class="section-label" data-animate>// how credit reporting works</span>
      <h2 data-animate style="margin-bottom: 16px;">Furnishers → Bureaus → You.</h2>
      <p data-animate style="max-width: 64ch; opacity: 0.7; margin-bottom: 32px;">Credit reporting is a pipeline. Furnishers (lenders, creditors, collection agencies) supply account data to the three major credit bureaus (Experian, Equifax, TransUnion). The bureaus store it in your file. You have the right under the FCRA to see this data, dispute inaccuracies, and demand investigation.</p>

      <table data-animate style="margin-bottom: 32px;">
        <thead>
          <tr><th>Step</th><th>Who acts</th><th>What happens</th><th>FCRA section</th></tr>
        </thead>
        <tbody>
          {reportingSteps.map((r) => (
            <tr>
              <td><span class="stat-gold" style="font-weight: 700;">{r.step}</span></td>
              <td style="font-weight: 600;">{r.actor}</td>
              <td style="opacity: 0.8;">{r.action}</td>
              <td class="mono" style="font-size: 12px;">{r.fcra}</td>
            </tr>
          ))}
        </tbody>
      </table>

      <div data-animate class="card" style="margin-bottom: 16px;">
        <h4 style="margin-bottom: 8px; text-transform: none; letter-spacing: -0.01em;">Key concept: Furnishers have duties</h4>
        <p style="font-size: 14px; opacity: 0.8;">Under FCRA §623, furnishers must provide accurate information, correct errors, and notify bureaus when they determine information is inaccurate. They must also conduct reasonable investigations when a consumer disputes directly with them. If a furnisher fails to investigate or correct, that is a violation.</p>
      </div>
    </div>
  </section>

  <hr class="rule" />

  <!-- Step-by-step dispute walkthrough -->
  <section class="section">
    <div class="container">
      <span class="section-label" data-animate>// step-by-step dispute walkthrough</span>
      <h2 data-animate style="margin-bottom: 48px;">The 7-step dispute process.</h2>

      <div data-animate data-animate-stagger="0.06" style="border: 1px solid var(--line);">
        {disputeSteps.map((s, i) => (
          <div style="display: grid; grid-template-columns: 80px 1fr; gap: 0; border-bottom: 1px solid var(--line);">
            <div style="padding: 32px; border-right: 1px solid var(--line); display: flex; align-items: flex-start;">
              <span class="stat-gold" style="font-size: 1.5rem; font-weight: 700; font-family: var(--font-mono);">{s.num}</span>
            </div>
            <div style="padding: 32px;">
              <h3 style="margin-bottom: 8px;">{s.title}</h3>
              <p style="font-size: 14px; opacity: 0.7; line-height: 1.75; max-width: 70ch;">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <hr class="rule" />

  <!-- Bureau addresses -->
  <section class="section">
    <div class="container">
      <span class="section-label" data-animate>// bureau contact information</span>
      <h2 data-animate style="margin-bottom: 16px;">Where to send your disputes.</h2>
      <p data-animate style="max-width: 50ch; opacity: 0.7; margin-bottom: 32px;">Send separate letters to each bureau. Certified Mail with Return Receipt — no exceptions.</p>

      <div data-animate data-animate-stagger="0.08" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 0; border: 1px solid var(--line);">
        {bureauAddresses.map((b) => (
          <div style="padding: 28px; border-right: 1px solid var(--line); border-bottom: 1px solid var(--line);">
            <span class="mono" style="font-size: 12px; color: var(--blue); letter-spacing: 0.1em; text-transform: uppercase;">// credit bureau</span>
            <h4 style="margin-top: 12px; margin-bottom: 12px; text-transform: none; letter-spacing: -0.01em; font-size: 1.15rem;">{b.name}</h4>
            <p class="mono" style="font-size: 13px; opacity: 0.7; line-height: 1.7;">{b.address}</p>
            <p class="mono" style="font-size: 13px; opacity: 0.7; margin-top: 4px;">{b.phone}</p>
            <p style="margin-top: 12px;"><a href={'https://' + b.online} style="font-size: 13px;">{b.online} →</a></p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <hr class="rule" />

  <!-- Letter template: Inaccurate Information -->
  <section class="section">
    <div class="container">
      <span class="section-label" data-animate>// template 01 — inaccurate information</span>
      <h2 data-animate style="margin-bottom: 16px;">Dispute Letter: Inaccurate Information</h2>
      <p data-animate style="max-width: 60ch; opacity: 0.7; margin-bottom: 24px;">Use when the reported balance, account status, payment history, or dates are wrong. This is the most common dispute scenario.</p>

      <div data-animate style="display: flex; gap: 16px; margin-bottom: 32px;">
        <button class="btn btn-primary" onclick="navigator.clipboard.writeText(document.getElementById('letter-inaccurate').textContent)">Copy letter</button>
        <a href="/personal-credit" class="btn btn-ghost">Back to hub</a>
      </div>

      <div id="letter-inaccurate" class="mono-block" style="margin-bottom: 48px;">
[YOUR NAME]
[YOUR ADDRESS]
[YOUR CITY, STATE ZIP]
[YOUR PHONE]
[YOUR EMAIL]
[YOUR DATE OF BIRTH]
[YOUR SOCIAL SECURITY NUMBER]

[DATE]

[EXPERIAN / EQUIFAX / TRANSUNION]
[BUREAU ADDRESS]

RE: Dispute of Inaccurate Information

Account: [ACCOUNT NUMBER]
Creditor: [CREDITOR NAME]
Amount Reported: [AMOUNT]

To Whom It May Concern,

I am writing to dispute the above-referenced account
appearing on my credit report. Pursuant to 15 U.S.C.
Section 1681i (Section 611 of the Fair Credit Reporting
Act), I am exercising my right to dispute this item.

The information being reported is inaccurate because:
[Explain specifically what is wrong — e.g., "The
reported balance of $X is incorrect. The actual balance
is $Y as of [DATE]." or "The account is reported as
open/late but was closed/current as of [DATE]."]

I have enclosed documentation supporting my position:
[List enclosures — e.g., account statement, payment
records, settlement letter]

I request that you investigate this dispute within 30
days as required by FCRA Section 1681i(a)(1). If you
cannot verify this account with complete and accurate
documentation, I request that you permanently delete
it from my credit file.

Please send me an updated copy of my credit report once
the investigation is complete, as required by FCRA
Section 1681j.

Sincerely,

[YOUR NAME]

Enclosures:
- Copy of credit report with disputed item highlighted
- Supporting documentation
      </div>
    </div>
  </section>

  <hr class="rule" />

  <!-- Letter template: Unverifiable -->
  <section class="section">
    <div class="container">
      <span class="section-label" data-animate>// template 02 — unverifiable information</span>
      <h2 data-animate style="margin-bottom: 16px;">Dispute Letter: Unverifiable Information</h2>
      <p data-animate style="max-width: 60ch; opacity: 0.7; margin-bottom: 24px;">Use when you have no record of the account, the creditor cannot produce documentation, or the account was never validated. If the bureau cannot verify, it must delete.</p>

      <div data-animate style="display: flex; gap: 16px; margin-bottom: 32px;">
        <button class="btn btn-primary" onclick="navigator.clipboard.writeText(document.getElementById('letter-unverifiable').textContent)">Copy letter</button>
      </div>

      <div id="letter-unverifiable" class="mono-block" style="margin-bottom: 48px;">
[YOUR NAME]
[YOUR ADDRESS]
[YOUR CITY, STATE ZIP]
[YOUR PHONE]
[YOUR EMAIL]

[DATE]

[EXPERIAN / EQUIFAX / TRANSUNION]
[BUREAU ADDRESS]

RE: Dispute of Unverifiable Account

Account: [ACCOUNT NUMBER]
Creditor: [CREDITOR NAME]
Amount: [AMOUNT]

To Whom It May Concern,

I am writing to dispute the above-referenced account on
my credit report. Pursuant to 15 U.S.C. Section 1681i
(FCRA Section 611), I am requesting a reinvestigation
of this item.

I have no record of this account. I do not recall
opening this account, and I have never received
documentation establishing its validity. I previously
requested validation from the furnisher under FDCPA
Section 1692g and did not receive adequate verification.

If this account cannot be verified with complete and
accurate documentation — including the original
creditor agreement, account statements, and chain of
assignment — I request that you permanently delete
this item from my credit file.

Please investigate within 30 days as required by FCRA
Section 1681i(a)(1) and send me written results within
5 business days of completion per Section 1681i(a)(6).

Sincerely,

[YOUR NAME]

Enclosures:
- Copy of credit report with disputed item highlighted
- Copy of prior validation request (if applicable)
      </div>
    </div>
  </section>

  <hr class="rule" />

  <!-- Letter template: Identity Theft -->
  <section class="section">
    <div class="container">
      <span class="section-label" data-animate>// template 03 — identity theft</span>
      <h2 data-animate style="margin-bottom: 16px;">Dispute Letter: Identity Theft (FCRA §605B Block)</h2>
      <p data-animate style="max-width: 60ch; opacity: 0.7; margin-bottom: 24px;">Use when an account was opened fraudulently in your name. Under FCRA §605B, you can block information resulting from identity theft by providing an identity theft report and a sworn statement.</p>

      <div data-animate style="display: flex; gap: 16px; margin-bottom: 32px;">
        <button class="btn btn-primary" onclick="navigator.clipboard.writeText(document.getElementById('letter-idtheft').textContent)">Copy letter</button>
      </div>

      <div id="letter-idtheft" class="mono-block" style="margin-bottom: 48px;">
[YOUR NAME]
[YOUR ADDRESS]
[YOUR CITY, STATE ZIP]
[YOUR PHONE]
[YOUR EMAIL]

[DATE]

[EXPERIAN / EQUIFAX / TRANSUNION]
[BUREAU ADDRESS]

RE: Block of Information Resulting from Identity Theft
    FCRA Section 605B (15 U.S.C. Section 1681c-2)

Account: [FRAUDULENT ACCOUNT NUMBER]
Creditor: [CREDITOR NAME]

To Whom It May Concern,

I am a victim of identity theft. The above-referenced
account was opened in my name without my authorization
by someone other than me. I did not open this account,
I did not authorize anyone to open this account on my
behalf, and I have never used or benefited from this
account.

Pursuant to FCRA Section 605B (15 U.S.C. Section
1681c-2), I am requesting that you block the reporting
of any information in my credit file that resulted from
identity theft.

I am enclosing the following required documentation:

1. A copy of my FTC Identity Theft Report filed at
   IdentityTheft.gov (or a police report)
2. A sworn statement that the information is not the
   result of any transaction conducted by me
3. Proof of identity (copy of driver's license and
   a utility bill)

Upon receipt of this information, you must block the
reporting of this information within 4 business days
and notify the furnisher that the information has been
blocked. You may not sell or transfer the blocked
information to another entity.

Sincerely,

[YOUR NAME]

Enclosures:
- FTC Identity Theft Report / Police Report
- Sworn statement (notarized)
- Copy of government-issued ID
- Utility bill for address verification
      </div>
    </div>
  </section>

  <hr class="rule" />

  <!-- Letter template: Obsolete Debt -->
  <section class="section">
    <div class="container">
      <span class="section-label" data-animate>// template 04 — obsolete debt</span>
      <h2 data-animate style="margin-bottom: 16px;">Dispute Letter: Obsolete Debt (Past Reporting Period)</h2>
      <p data-animate style="max-width: 60ch; opacity: 0.7; margin-bottom: 24px;">Use when a negative item is being reported beyond the legal time limit. Most items must be removed after 7 years; bankruptcies after 10 years; paid tax liens after 7 years.</p>

      <div data-animate style="display: flex; gap: 16px; margin-bottom: 32px;">
        <button class="btn btn-primary" onclick="navigator.clipboard.writeText(document.getElementById('letter-obsolete').textContent)">Copy letter</button>
      </div>

      <div id="letter-obsolete" class="mono-block" style="margin-bottom: 48px;">
[YOUR NAME]
[YOUR ADDRESS]
[YOUR CITY, STATE ZIP]
[YOUR PHONE]
[YOUR EMAIL]

[DATE]

[EXPERIAN / EQUIFAX / TRANSUNION]
[BUREAU ADDRESS]

RE: Obsolete Information — Request for Deletion
    FCRA Section 605 (15 U.S.C. Section 1681c)

Account: [ACCOUNT NUMBER]
Creditor: [CREDITOR NAME]
Date of First Delinquency: [APPROXIMATE DATE]

To Whom It May Concern,

I am writing to dispute the continued reporting of the
above-referenced account on my credit report. Pursuant
to FCRA Section 605 (15 U.S.C. Section 1681c), this
item is being reported beyond the permissible reporting
period.

The Date of First Delinquency for this account was on
or about [MONTH/YEAR]. Under FCRA Section 605(a),
adverse items may not be reported after 7 years from
the date of first delinquency, or in the case of
Chapter 7 bankruptcy, after 10 years.

This item has exceeded the maximum reporting period and
must be deleted from my credit file immediately.

I request that you:
1. Remove this item from my credit report
2. Notify me in writing within 30 days of the deletion
3. Provide an updated copy of my credit report

Sincerely,

[YOUR NAME]

Enclosures:
- Copy of credit report showing the item and its dates
- Any documentation showing the date of first delinquency
      </div>
    </div>
  </section>

  <hr class="rule" />

  <!-- Letter template: Mixed File -->
  <section class="section">
    <div class="container">
      <span class="section-label" data-animate>// template 05 — mixed file</span>
      <h2 data-animate style="margin-bottom: 16px;">Dispute Letter: Mixed Credit File</h2>
      <p data-animate style="max-width: 60ch; opacity: 0.7; margin-bottom: 24px;">Use when someone else's accounts or personal information appear on your credit report due to a file merge error — often caused by similar names, shared addresses, or close Social Security numbers.</p>

      <div data-animate style="display: flex; gap: 16px; margin-bottom: 32px;">
        <button class="btn btn-primary" onclick="navigator.clipboard.writeText(document.getElementById('letter-mixed').textContent)">Copy letter</button>
      </div>

      <div id="letter-mixed" class="mono-block" style="margin-bottom: 48px;">
[YOUR NAME]
[YOUR ADDRESS]
[YOUR CITY, STATE ZIP]
[YOUR PHONE]
[YOUR EMAIL]
[YOUR DATE OF BIRTH]
[YOUR SOCIAL SECURITY NUMBER]

[DATE]

[EXPERIAN / EQUIFAX / TRANSUNION]
[BUREAU ADDRESS]

RE: Mixed File — Accounts Belonging to Another Consumer

To Whom It May Concern,

I am writing to dispute accounts appearing on my credit
report that do not belong to me. It appears that my
credit file has been mixed with another consumer's
information. This is a serious inaccuracy under FCRA
Section 611.

The following accounts are NOT mine:
1. [CREDITOR NAME] — Account [NUMBER]
2. [CREDITOR NAME] — Account [NUMBER]
3. [CREDITOR NAME] — Account [NUMBER]

I believe these accounts may belong to another person
who shares a similar name, address, or Social Security
number. I am providing my identifying information above
so that you can properly segregate my file.

I request that you:
1. Remove all accounts that do not belong to me
2. Verify that my file contains only my information
3. Assign or reassign a unique identifier to my file
4. Provide me with an updated credit report

Please investigate within 30 days per FCRA Section
1681i(a)(1) and send written results within 5 business
days of completion.

Sincerely,

[YOUR NAME]

Enclosures:
- Copy of credit report with disputed items highlighted
- Copy of driver's license or state ID
- Copy of Social Security card
- Recent utility bill for address verification
      </div>
    </div>
  </section>

  <hr class="rule" />

  <!-- MOV Request Letter -->
  <section class="section">
    <div class="container">
      <span class="section-label" data-animate>// method of verification (MOV) request</span>
      <h2 data-animate style="margin-bottom: 16px;">MOV Request Letter</h2>
      <p data-animate style="max-width: 64ch; opacity: 0.7; margin-bottom: 16px;">When a bureau verifies a disputed item without removing it, you have the right under FCRA §611(a)(7) to request a description of the procedure used to determine the accuracy and completeness of the information. This is called a Method of Verification (MOV) request. Send it within 15 days of receiving the bureau's verification notice.</p>
      <p data-animate style="max-width: 64ch; opacity: 0.7; margin-bottom: 32px;">The bureau must respond within 15 days with the business name, address, and phone number of the furnisher they contacted, and a description of how they verified. If they cannot provide this, the item must be deleted.</p>

      <div data-animate style="display: flex; gap: 16px; margin-bottom: 32px;">
        <button class="btn btn-primary" onclick="navigator.clipboard.writeText(document.getElementById('letter-mov').textContent)">Copy letter</button>
      </div>

      <div id="letter-mov" class="mono-block" style="margin-bottom: 48px;">
[YOUR NAME]
[YOUR ADDRESS]
[YOUR CITY, STATE ZIP]
[YOUR PHONE]
[YOUR EMAIL]

[DATE]

[EXPERIAN / EQUIFAX / TRANSUNION]
[BUREAU ADDRESS]

RE: Request for Method of Verification
    FCRA Section 611(a)(7) — 15 U.S.C. Section 1681i(a)(7)

Account: [ACCOUNT NUMBER]
Creditor: [CREDITOR NAME]
Date of Bureau's Verification Notice: [DATE]

To Whom It May Concern,

On [DATE], I received notice from your agency that the
above-referenced dispute was verified and the item would
remain on my credit report.

Pursuant to FCRA Section 611(a)(7), I am requesting a
description of the procedure used to determine the
accuracy and completeness of the information.

Specifically, I request that you provide:
1. The business name, address, and telephone number of
   the furnisher you contacted
2. A description of the method used to verify the
   information (e.g., e-OSCAR, direct contact, etc.)
3. The specific documentation reviewed during
   verification
4. The name and contact information of the person who
   conducted the verification

If you cannot provide this information within 15 days,
the item must be deleted from my credit file as
unverifiable.

Sincerely,

[YOUR NAME]
      </div>
    </div>
  </section>

  <hr class="rule" />
</Base>
