  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Caleb Pierre",
  "url": "https://creditcookbook.com/about",
  "image": "https://creditcookbook.com/about#person",
  "jobTitle": "Security Engineer / Fintech CTO / AI Automation Specialist",
  "worksFor": {
    "@type": "Organization",
    "name": "Caleb Pierre Ventures LLC"
  },
  "sameAs": [
    "https://calebpierre.com",
