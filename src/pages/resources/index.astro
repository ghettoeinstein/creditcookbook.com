---
import Base from '../../layouts/Base.astro';
import EmailCapture from '../../components/EmailCapture.astro';

const description = 'Credit resources — statutes, bureau contact info, consumer protection agencies, glossary, and external references. Everything you need to understand and enforce your credit rights.';

const resources = [
  { num: '01', title: 'FCRA — Fair Credit Reporting Act', desc: 'The primary statute governing credit reporting. 15 U.S.C. § 1681.', link: 'https://www.consumerfinance.gov/learnmore/credit-reporting/', external: true, status: 'live' },
  { num: '02', title: 'FDCPA — Fair Debt Collection Practices Act', desc: 'Federal law governing debt collectors. 15 U.S.C. § 1692.', link: 'https://www.consumerfinance.gov/learnmore/debt-collection/', external: true, status: 'live' },
  { num: '03', title: 'CFPB Complaint Portal', desc: 'File a complaint against a credit bureau, collection agency, or creditor.', link: 'https://www.consumerfinance.gov/complaint/', external: true, status: 'live' },
  { num: '04', title: 'AnnualCreditReport.com', desc: 'Free annual credit reports from all three bureaus — the only official source.', link: 'https://www.annualcreditreport.com', external: true, status: 'live' },
  { num: '05', title: 'Bureau Contact Directory', desc: 'Phone numbers, addresses, and dispute portals for Equifax, Experian, and TransUnion.', link: '#', external: false, status: 'coming soon' },
  { num: '06', title: 'Credit Glossary', desc: 'Definitions for every credit term used on this site — from "charge-off" to "trade line".', link: '#', external: false, status: 'coming soon' },
  { num: '07', title: 'State-by-State Statutes of Limitation', desc: 'How long collectors can legally sue you for a debt in each state.', link: '#', external: false, status: 'coming soon' },
  { num: '08', title: 'HIPAA Resource Guide', desc: 'How HIPAA intersects with credit reporting and medical debt collection.', link: '#', external: false, status: 'coming soon' },
];
---

<Base title="Resources — CreditCookbook" description={description} posterTitle="RESOURCES" posterLabel="// statutes, references, and tools">
  <section class="section">
    <div class="container">
      <span class="section-label">// credit resources</span>
      <h2 style="margin-bottom: 16px;">The reference library.</h2>
      <p style="max-width: 50ch; opacity: 0.7; margin-bottom: 48px;">Statutes, consumer protection agencies, bureau contacts, glossary terms, and external references. Everything you need to understand and enforce your credit rights — all in one place.</p>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 0; border: 1px solid var(--line);">
        {resources.map((r) => (
          r.status === 'live' && r.external ? (
            <a href={r.link} target="_blank" rel="noopener" style="display: block; padding: 32px; border-right: 1px solid var(--line); border-bottom: 1px solid var(--line); text-decoration: none; color: var(--ink);">
              <span class="section-label" style="margin-bottom: 8px;">// resource {r.num}</span>
              <h4 style="margin-bottom: 6px; text-transform: none; letter-spacing: -0.01em; font-size: 1.1rem;">{r.title}</h4>
              <p style="font-size: 13px; opacity: 0.7;">{r.desc}</p>
              <p class="mono" style="margin-top: 16px; color: var(--blue); font-size: 12px;">visit →</p>
            </a>
          ) : r.status === 'live' ? (
            <a href={r.link} style="display: block; padding: 32px; border-right: 1px solid var(--line); border-bottom: 1px solid var(--line); text-decoration: none; color: var(--ink);">
              <span class="section-label" style="margin-bottom: 8px;">// resource {r.num}</span>
              <h4 style="margin-bottom: 6px; text-transform: none; letter-spacing: -0.01em; font-size: 1.1rem;">{r.title}</h4>
              <p style="font-size: 13px; opacity: 0.7;">{r.desc}</p>
              <p class="mono" style="margin-top: 16px; color: var(--blue); font-size: 12px;">read →</p>
            </a>
          ) : (
            <div style="padding: 32px; border-right: 1px solid var(--line); border-bottom: 1px solid var(--line); opacity: 0.4;">
              <span class="section-label" style="margin-bottom: 8px;">// resource {r.num} — coming soon</span>
              <h4 style="margin-bottom: 6px; text-transform: none; letter-spacing: -0.01em; font-size: 1.1rem;">{r.title}</h4>
              <p style="font-size: 13px;">{r.desc}</p>
              <p class="mono" style="margin-top: 16px; font-size: 12px;">coming soon</p>
            </div>
          )
        ))}
      </div>
    </div>
  </section>

  <hr class="rule" />

  <!-- Quick reference -->
  <section class="section">
    <div class="container">
      <span class="section-label">// quick reference</span>
      <h2 style="margin-bottom: 32px;">Key numbers to know.</h2>
      <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; border: 1px solid var(--line);">
        <div style="padding: 28px; border-right: 1px solid var(--line);">
          <span class="mono" style="font-size: 28px; font-weight: 600; color: var(--blue); display: block;">7 yrs</span>
          <span class="mono" style="font-size: 11px; letter-spacing: 0.05em; opacity: 0.6;">MAX REPORTING TIME</span>
        </div>
        <div style="padding: 28px; border-right: 1px solid var(--line);">
          <span class="mono" style="font-size: 28px; font-weight: 600; color: var(--blue); display: block;">$500</span>
          <span class="mono" style="font-size: 11px; letter-spacing: 0.05em; opacity: 0.6;">MEDICAL DEBT THRESHOLD</span>
        </div>
        <div style="padding: 28px; border-right: 1px solid var(--line);">
          <span class="mono" style="font-size: 28px; font-weight: 600; color: var(--blue); display: block;">30 days</span>
          <span class="mono" style="font-size: 11px; letter-spacing: 0.05em; opacity: 0.6;">BUREAU RESPONSE WINDOW</span>
        </div>
        <div style="padding: 28px;">
          <span class="mono" style="font-size: 28px; font-weight: 600; color: var(--blue); display: block;">45 days</span>
          <span class="mono" style="font-size: 11px; letter-spacing: 0.05em; opacity: 0.6;">PAID MEDICAL REMOVAL</span>
        </div>
      </div>
    </div>
  </section>

  <hr class="rule" />

  <EmailCapture />

</Base>
