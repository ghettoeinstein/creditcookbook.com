---
import Base from '../../../layouts/Base.astro';

const description = "Debt collector cease contact letter — 'Stop contacting me.' Tell a debt collector to stop all communication under federal law (FDCPA).";
---

<Base title="Debt Collector: Cease Contact Letter — CreditCookbook" description={description} posterTitle="CEASE CONTACT" posterLabel="// debt collector response template">
  <section class="section" data-animate>
    <div class="container">
      <span class="section-label" data-animate>// debt collector response — cease contact</span>
      <h2 data-animate style="margin-bottom: 16px;">"Stop Contacting Me"</h2>
      <p data-animate style="max-width: 60ch; margin-bottom: 32px; opacity: 0.7;">Use this letter to tell a debt collector to stop contacting you. Under federal law (FDCPA), a debt collector must stop contacting you after receiving a written request to stop. They can still contact you to say they won't contact you again, or to notify you that the creditor or debt collector could take other action (such as filing a lawsuit). Stopping contact does not cancel the debt.</p>

      <div style="display: flex; gap: 16px; margin-bottom: 48px;" data-animate>
        <button class="btn btn-primary" onclick="navigator.clipboard.writeText(document.getElementById('letter').textContent)">Copy letter</button>
        <a href="/recipes/dispute-letters" class="btn btn-ghost">Back to dispute letters</a>
      </div>

      <div id="letter" class="mono-block" style="margin-bottom: 48px;" data-animate>
[YOUR NAME]
[YOUR RETURN ADDRESS]
[DATE]

[DEBT COLLECTOR NAME]
[DEBT COLLECTOR ADDRESS]

Re: [ACCOUNT NUMBER FOR THE DEBT, IF YOU HAVE IT]

Dear debt collector,

I am responding to your contact about a debt you are
attempting to collect. You contacted me by [PHONE/MAIL],
on [DATE]. You identified the debt as [ANY INFORMATION
THEY GAVE YOU ABOUT THE DEBT].

Please stop all communication with me and with this
address about this debt.

Record that I dispute having any obligation for this debt.
If you stop collection of this debt, and forward or return
it to another company, please indicate to them that it is
disputed. If you report it to a credit bureau (or have
already done so), also report that the debt is disputed.

Thank you for your cooperation.

Sincerely,

[YOUR NAME]
      </div>

      <div class="card" data-animate>
        <h4 style="margin-bottom: 12px;">Sending instructions</h4>
        <ul style="margin-left: 24px; line-height: 2;">
          <li>Fill in your information on the template and edit as needed</li>
          <li>Delete the paragraph about disputing the debt if you don't dispute it</li>
          <li>Print and send the letter — keep a copy for your records</li>
          <li>Send via certified mail with return receipt</li>
          <li>Under federal law, the collector must stop contacting you after receiving this letter</li>
          <li>The collector can still contact you to confirm they will stop, or to notify you of legal action</li>
          <li>Stopping contact does not cancel the debt — you could still be sued</li>
          <li>You can ask a collector to stop at any time, but consider requesting information first</li>
        </ul>
      </div>
    </div>
  </section>

  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "Debt Collector Cease Contact Letter",
    "description": "Letter to instruct a debt collector to stop all communication under the FDCPA.",
    "totalTime": "PT10M",
    "step": [
      {"@type": "HowToStep", "name": "Fill in your information", "text": "Complete your name, return address, and the date at the top of the letter."},
      {"@type": "HowToStep", "name": "Add debt collector details", "text": "Fill in the debt collector's name, address, and the account number if you have it."},
      {"@type": "HowToStep", "name": "Decide on dispute paragraph", "text": "Delete the paragraph about disputing the debt if you do not dispute it."},
      {"@type": "HowToStep", "name": "Print and mail", "text": "Print the letter and mail it via certified mail with return receipt. Keep a copy for your records."}
    ]
  })} />
</Base>
